# Environment Configuration
# Copy this file to .env and fill in your actual API keys

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# 2Captcha Configuration
CAPTCHA_API_KEY=your_2captcha_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///./maha_verify.db
# For PostgreSQL: postgresql://user:password@localhost/maha_verify

# JWT Secret
SECRET_KEY=your-super-secret-key-change-this-in-production

# Server Configuration
DEBUG=True
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=209715200  # 200MB in bytes

# RERA Portal
RERA_PORTAL_URL=https://maharera.mahaonline.gov.in
RERA_PORTAL_TIMEOUT=30
